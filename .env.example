# ─── Database ─────────────────────────────────────────────────
# Local dev: SQLite
DATABASE_URL="file:./apps/web/prisma/dev.db"
# Production (Cloud SQL via Unix socket):
# DATABASE_URL="postgresql://slideshow:PASSWORD@/db?host=/cloudsql/ai-agent-dev-486423:us-central1:slideshow-db&dbname=slideshow"

# ─── Redis (optional) ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Leave empty to use in-memory fallback (works fine for single-instance)

# ─── PPTX Pipeline Service ────────────────────────────────────
PIPELINE_URL="http://localhost:8100"
# Production: set by Cloud Run deploy automatically

# ─── Auth ─────────────────────────────────────────────────────
AUTH_SECRET="change-me-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI Providers ─────────────────────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
AI_PROVIDER="anthropic"

# ─── Socket.io / Realtime ─────────────────────────────────────
NEXT_PUBLIC_REALTIME_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google Cloud (production only) ───────────────────────────
GCP_PROJECT="ai-agent-dev-486423"
GCS_BUCKET="slideshow-uploads-ai-agent-dev-486423"
# Leave unset in dev — files will be stored locally in public/uploads/
