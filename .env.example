# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./apps/web/prisma/dev.db"

# Redis (optional - app works without it)
REDIS_URL="redis://localhost:6379"

# PPTX Pipeline Service (optional - runs via Docker)
PPTX_PIPELINE_URL="http://localhost:8100"

# Auth
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# AI Providers (configurable - set one or both)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
AI_PROVIDER="anthropic"  # "anthropic" | "openai"

# Socket.io
NEXT_PUBLIC_SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
